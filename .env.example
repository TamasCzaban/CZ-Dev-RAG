# ============================================================================
# CZ-Dev-RAG — configuration
#
# Copy this file to .env and fill in secrets.
#   cp .env.example .env
#
# `.env` is gitignored. Do NOT commit it.
# All variables have sensible defaults in docker-compose.yml, so the stack
# will boot even if you leave .env empty — but production use requires at
# least the LANGFUSE_* secrets and a real LLM model pulled in Ollama.
# ============================================================================


# ------------------------------------------------------------
# OCR host tooling (Windows — set to your actual install paths)
# ------------------------------------------------------------

# Full path to tesseract.exe. Needed when Tesseract is not on PATH
# (e.g., fresh winget install before a shell restart).
# Install: winget install -e --id UB-Mannheim.TesseractOCR
# Then download hun.traineddata from github.com/tesseract-ocr/tessdata
# into C:\Program Files\Tesseract-OCR\tessdata\
TESSERACT_CMD="C:/Program Files/Tesseract-OCR/tesseract.exe"

# Directory containing pdftoppm / pdfinfo (Poppler).
# Install: winget install -e --id oschwartz10612.Poppler
POPPLER_PATH="C:/Users/<you>/AppData/Local/Microsoft/WinGet/Packages/oschwartz10612.Poppler_Microsoft.Winget.Source_8wekyb3d8bbwe/poppler-25.07.0/Library/bin"


# ------------------------------------------------------------
# Ollama (runs natively on the Windows host — not in a container)
# ------------------------------------------------------------

# The container-side URL `http://host.docker.internal:11434` is HARDCODED
# in docker-compose.yml. We can't interpolate it from .env because the
# `OLLAMA_HOST` shell env var on Windows is reserved for telling
# `ollama serve` which interface to bind to (commonly `0.0.0.0`) — compose
# interpolation would collide and containers would receive a bind-interface
# string instead of a URL. If you relocate Ollama off localhost, edit
# docker-compose.yml directly.

# >>> REQUIRED HOST SETTING <<<
# You MUST disable Ollama flash attention on the host before first ingestion,
# or BGE-M3 will return NaN embeddings during LightRAG's merging stage (HTTP 500:
# "failed to encode response: json: unsupported value: NaN"). This is an upstream
# Ollama bug (github.com/ollama/ollama/issues/13572), not a LightRAG issue.
#
# On Windows:  setx OLLAMA_FLASH_ATTENTION false  (then restart ollama.exe)
# On Linux:    export OLLAMA_FLASH_ATTENTION=false  in Ollama's systemd unit
#
# See LEARNINGS.md § "BGE-M3 NaN Embeddings" for the full RCA.


# ------------------------------------------------------------
# LightRAG models
# ------------------------------------------------------------

# Large language model for entity + relation extraction during ingestion
# and for final-answer generation. Qwen2.5-32B Q4_K_M uses ~18 GB VRAM.
# Pull it first: `ollama pull qwen2.5:32b-instruct-q4_K_M`
# Don't downgrade without reading docs/DECISIONS.md § ADR-003.
LLM_MODEL=qwen2.5:32b-instruct-q4_K_M

# Embedding model. BGE-M3 is multilingual (including Hungarian) at 1024 dim.
# Pull it: `ollama pull bge-m3`
# Don't swap without reindexing everything — see docs/DECISIONS.md § ADR-002.
EMBEDDING_MODEL=bge-m3:latest
EMBEDDING_DIM=1024


# ------------------------------------------------------------
# LightRAG behavior
# ------------------------------------------------------------

# Port the LightRAG web UI + API binds to on the host.
LIGHTRAG_PORT=9621

# Default retrieval mode when the UI doesn't specify.
# One of: naive | local | global | hybrid
LIGHTRAG_MODE_DEFAULT=hybrid

# Working directory inside the container where the graph + vectors live.
# Mapped to ./data/rag_storage on the host (gitignored).
WORKING_DIR=/app/data/rag_storage

# Max concurrent document ingestion pipelines. On a single 3090 with Qwen2.5-32B
# + BGE-M3, 1 is the safe default for a FRESH setup. After applying the
# OLLAMA_FLASH_ATTENTION=false fix above (the actual NaN root cause), you can
# raise to 2. Going to 4 is feasible if you also set OLLAMA_NUM_PARALLEL=2 on
# the Ollama host (`setx OLLAMA_NUM_PARALLEL 2` then restart ollama.exe) — without
# that, Ollama serializes inbound requests and extra workers just queue.
# Multi-GPU or dedicated embedding hardware can go higher still.
MAX_ASYNC=1

# LLM worker timeout in seconds for entity extraction queue.
# LightRAG's worker calculates max_execution = LLM_TIMEOUT * 2, so 1800 → 60 min max.
# DO NOT set to 0 — LightRAG treats it literally (timeout after 0s), not infinite.
# Qwen2.5-32B entity extraction with MAX_ASYNC=2 can queue 10+ min per chunk.
LLM_TIMEOUT=1800

# Embedding worker timeout. BGE-M3 is fast; 300s (→ 600s max execution) is plenty.
EMBEDDING_TIMEOUT=300

# Max concurrent embedding calls. LightRAG default is 8. The NaN bug that
# prompted lowering this was a flash-attention overflow (see OLLAMA_FLASH_ATTENTION
# section above), not an embedding concurrency issue. 2 is conservative; with
# OLLAMA_FLASH_ATTENTION=false applied, 8 is fine on a single 3090.
EMBEDDING_FUNC_MAX_ASYNC=2


# ------------------------------------------------------------
# Reranker -- BGE-reranker-v2-m3 via infinity-emb (wired in phase 03)
# ------------------------------------------------------------

# Model pulled automatically by the infinity-emb container on first start.
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Initial retrieval width sent to LightRAG. The reranker then scores all
# top-k chunks and returns only top_n to the LLM.
RERANK_TOP_K=20

# Final number of passages forwarded to the LLM after reranking.
RERANK_TOP_N=5

# Base URL of the reranker service. Inside Docker compose the service name
# resolves via Docker DNS. Override to http://localhost:7997 for local dev
# when running the reranker outside Docker.
RERANK_HOST=http://reranker:7997


# ------------------------------------------------------------
# Langfuse (self-hosted tracing — full wiring lands in phase 10)
# ------------------------------------------------------------

# Port the Langfuse web UI binds to.
LANGFUSE_PORT=3000

# Public URL of Langfuse (used for NEXTAUTH_URL).
LANGFUSE_HOST=http://localhost:3000

# Langfuse project API keys. Empty by default — after first Langfuse login,
# create a project and paste its keys here, then `docker compose restart`.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Postgres creds for the Langfuse database. Change these for a real deploy.
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=change-me-please
LANGFUSE_DB_NAME=langfuse

# Long random strings for NextAuth session signing + encryption.
# Generate with: `python -c "import secrets; print(secrets.token_urlsafe(48))"`
LANGFUSE_NEXTAUTH_SECRET=change-me-to-a-long-random-string-please
LANGFUSE_SALT=change-me-to-another-long-random-string-please

# Names shown in the Langfuse UI on first boot.
LANGFUSE_INIT_ORG_NAME=CZ Dev
LANGFUSE_INIT_PROJECT_NAME=cz-dev-rag


# ------------------------------------------------------------
# MCP server (lands in phase 07)
# ------------------------------------------------------------

MCP_SERVER_PORT=9622


# ------------------------------------------------------------
# OCR engine (phase 06)
# ------------------------------------------------------------

# Which OCR backend to use.  Options: auto | mineru | tesseract
# "auto" tries MinerU first and falls back to Tesseract when confidence
# is below OCR_ACCURACY_THRESHOLD.  "tesseract" is the safe default when
# the LightRAG container is not running (e.g. local dev, CI smoke test).
OCR_ENGINE=auto
OCR_ACCURACY_THRESHOLD=0.95
